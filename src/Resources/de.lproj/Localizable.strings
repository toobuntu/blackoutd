/* Menu item: restore the built-in display after blackout */
"Restore Built-in Display" = "Integrierten Bildschirm wiederherstellen";

/* Menu item: black out the built-in display */
"Black Out Built-in Display" = "Integrierten Bildschirm ausschalten";

/* Menu item: toggle automatic blackout when an external display connects */
"Auto-blackout on External Connect" = "Automatisches Ausschalten bei Anschluss eines externen Bildschirms";

/* Menu item: quit the daemon */
"Quit blackoutd" = "blackoutd beenden";
