# Pre-commit hook for blackoutd.
# Install: git config core.hooksPath .githooks

set -e

# Block direct commits to main.
branch=$(git branch --show-current)
if [ "$branch" = "main" ]; then
    echo "error: direct commits to main are not allowed. Create a feature branch." >&2
    exit 1
fi

# Check clang-format on staged .m and .h files.
# On macOS, use xcrun to find clang-format from Xcode toolchain.
# On Linux, use bare clang-format (e.g., from brew install clang-format).
if [ "$(uname -s)" = "Darwin" ]; then
    if xcrun --find clang-format >/dev/null 2>&1; then
        git diff --cached --name-only --diff-filter=ACM -z -- '*.m' '*.h' \
            | xargs -0 xcrun clang-format --style=file --dry-run --Werror
    fi
else
    if command -v clang-format >/dev/null 2>&1; then
        git diff --cached --name-only --diff-filter=ACM -z -- '*.m' '*.h' \
            | xargs -0 clang-format --style=file --dry-run --Werror
    fi
fi
