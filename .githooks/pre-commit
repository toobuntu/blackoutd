# Pre-commit hook for blackoutd.
# Install: git config core.hooksPath .githooks

set -e

staged() { git diff --cached --name-only --diff-filter=ACM | /usr/bin/grep -E "$1" || true; }

# Block direct commits to main.
branch=$(git branch --show-current)
if [ "$branch" = "main" ]; then
    printf 'error: direct commits to main are not allowed. Create a feature branch.\n' >&2
    exit 1
fi

# --- clang-format on staged .m and .h files ---
objc_files=$(staged '\.(m|h)$')
if [ -n "$objc_files" ]; then
    if [ "$(/usr/bin/uname -s)" = "Darwin" ]; then
        if xcrun --find clang-format >/dev/null 2>&1; then
            printf '%s\n' "$objc_files" | xargs xcrun clang-format --style=file --dry-run --Werror
        fi
    else
        if command -v clang-format >/dev/null 2>&1; then
            printf '%s\n' "$objc_files" | xargs clang-format --style=file --dry-run --Werror
        fi
    fi
fi

# --- clang-tidy on staged .m files (macOS only — requires SDK headers) ---
if [ "$(/usr/bin/uname -s)" = "Darwin" ]; then
    m_files=$(staged '\.m$')
    if [ -n "$m_files" ]; then
        TIDY=""
        if command -v clang-tidy >/dev/null 2>&1; then
            TIDY="clang-tidy"
        else
            LLVM_PREFIX="$(/bin/ls -d "$(brew --prefix)"/opt/llvm@* 2>/dev/null \
                | /usr/bin/sort -V | /usr/bin/tail -1)"
            if [ -n "$LLVM_PREFIX" ] && [ -x "$LLVM_PREFIX/bin/clang-tidy" ]; then
                TIDY="$LLVM_PREFIX/bin/clang-tidy"
            fi
        fi
        if [ -n "$TIDY" ]; then
            printf '%s\n' "$m_files" | xargs "$TIDY" -- \
                -fobjc-arc \
                -DBD_BUNDLE_ID='"io.github.toobuntu.blackoutd"' \
                -framework Cocoa \
                -framework CoreGraphics \
                -framework IOKit \
                -I src
        fi
    fi
fi

# --- Lint staged workflow files with actionlint and zizmor ---
workflow_files=$(staged '\.github/workflows/.*\.yml$')
if [ -n "$workflow_files" ]; then
    if command -v actionlint >/dev/null 2>&1; then
        printf '%s\n' "$workflow_files" | xargs actionlint
    else
        echo "warning: actionlint not found — skipping workflow lint (brew install actionlint)" >&2
    fi
    if command -v zizmor >/dev/null 2>&1; then
        zizmor .
    else
        echo "warning: zizmor not found — skipping workflow security scan (brew install zizmor)" >&2
    fi
fi

# --- REUSE compliance ---
if command -v reuse >/dev/null 2>&1; then
    if ! reuse lint --quiet; then
        reuse lint
        cat >&2 <<'HINT'

To annotate unannotated files, run:

  scripts/annotate.sh

HINT
        exit 1
    fi
else
    echo "warning: reuse not found — skipping REUSE compliance check (brew install reuse)" >&2
fi
