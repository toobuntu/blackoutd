# Pre-commit hook for blackoutd.
# Install: git config core.hooksPath .githooks

set -e

# Block direct commits to main.
branch=$(git branch --show-current)
if [ "$branch" = "main" ]; then
    echo "error: direct commits to main are not allowed. Create a feature branch." >&2
    exit 1
fi

# Check clang-format on staged .m and .h files.
staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.m' '*.h')
if [ -n "$staged" ]; then
    if command -v clang-format >/dev/null 2>&1; then
        echo "$staged" | xargs clang-format --style=file --dry-run --Werror
    fi
fi
