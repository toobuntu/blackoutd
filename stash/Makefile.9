BINARY      = blackoutd
INSTALL_BIN = /usr/local/bin/$(BINARY)
AGENT_DIR   = $(HOME)/Library/LaunchAgents
AGENT_PLIST = local.blackoutd.plist
AGENT_DST   = $(AGENT_DIR)/$(AGENT_PLIST)
UID         = $(shell id -u)

SRCS   = main.m AppDelegate.m DisplayController.m
CC     = clang
CFLAGS = \
    -fobjc-arc \
    -Wall \
    -Wextra \
    -framework Cocoa \
    -framework CoreGraphics \
    -sectcreate __TEXT __info_plist Info.plist

.PHONY: all clean install uninstall load unload update

all: $(BINARY)

$(BINARY): $(SRCS) AppDelegate.h DisplayController.h Info.plist
	$(CC) $(CFLAGS) -o $@ $(SRCS)
	codesign --sign - --force $(BINARY)

clean:
	rm -f $(BINARY)

# First-time install: build, install binary + plist, bootstrap agent.
install: $(BINARY)
	sudo install -d /usr/local/bin
	sudo install -m 755 $(BINARY) $(INSTALL_BIN)
	install -d $(AGENT_DIR)
	install -m 644 $(AGENT_PLIST) $(AGENT_DST)
	launchctl bootstrap gui/$(UID) $(AGENT_DST)

# Remove agent and binary.
uninstall: unload
	sudo rm -f $(INSTALL_BIN)
	rm -f $(AGENT_DST)

# Bootstrap the agent without reinstalling.
load:
	launchctl bootstrap gui/$(UID) $(AGENT_DST)

# Bootout the agent.
unload:
	-launchctl bootout gui/$(UID)/$(BINARY) 2>/dev/null

# Rebuild binary and restart agent in place; does not reinstall plist.
update: unload clean $(BINARY)
	sudo install -m 755 $(BINARY) $(INSTALL_BIN)
	launchctl bootstrap gui/$(UID) $(AGENT_DST)
