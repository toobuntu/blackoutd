#import "DisplayController.h"
#import <IOKit/graphics/IOGraphicsLib.h>

extern CGError CGSConfigureDisplayEnabled(CGDisplayConfigRef, CGDirectDisplayID, bool);

// Enumerates IOKit display services by class name, returning an iterator.
// Caller must release the iterator with IOObjectRelease.
static io_iterator_t displayServiceIterator(const char *serviceClass) {
    io_iterator_t iter = IO_OBJECT_NULL;
    IOServiceGetMatchingServices(kIOMainPortDefault,
                                 IOServiceMatching(serviceClass),
                                 &iter);
    return iter;
}

// Returns YES if a physical IOKit display service backs this CGDirectDisplayID.
// Virtual/placeholder displays inserted by macOS during display transitions
// have no display service entry and return NO.
// Tries AppleCLCD2 (Apple Silicon) then IODisplayConnect (Intel).
static BOOL displayHasIOKitService(CGDirectDisplayID displayID) {
    uint32_t vendor = CGDisplayVendorNumber(displayID);
    uint32_t model  = CGDisplayModelNumber(displayID);
    NSLog(@"blackoutd:     IOKit lookup for id=%u vendor=%u model=%u", displayID, vendor, model);

    const char *classes[] = { "AppleCLCD2", "IODisplayConnect", NULL };
    for (int ci = 0; classes[ci] != NULL; ci++) {
        io_iterator_t iter = displayServiceIterator(classes[ci]);
        if (iter == IO_OBJECT_NULL) continue;

        BOOL found = NO;
        io_service_t service;
        while (!found && (service = IOIteratorNext(iter))) {
            CFDictionaryRef info = IODisplayCreateInfoDictionary(service,
                                                                  kIODisplayMatchingInfo);
            if (info) {
                CFNumberRef vendorRef = CFDictionaryGetValue(info, CFSTR("DisplayVendorID"));
                CFNumberRef modelRef  = CFDictionaryGetValue(info, CFSTR("DisplayProductID"));
                uint32_t svcVendor = 0, svcModel = 0;
                if (vendorRef) CFNumberGetValue(vendorRef, kCFNumberSInt32Type, &svcVendor);
                if (modelRef)  CFNumberGetValue(modelRef,  kCFNumberSInt32Type, &svcModel);
                NSLog(@"blackoutd:     [%s] service vendor=%u model=%u", classes[ci], svcVendor, svcModel);
                if (svcVendor == vendor && svcModel == model) found = YES;
                CFRelease(info);
            }
            IOObjectRelease(service);
        }
        IOObjectRelease(iter);
        if (found) return YES;
    }
    return NO;
}

static void displayReconfigCallback(CGDirectDisplayID displayID,
                                    CGDisplayChangeSummaryFlags flags,
                                    void *userInfo) {
    DisplayController *controller = (__bridge DisplayController *)userInfo;
    [controller handleReconfiguration:displayID flags:flags];
}

@implementation DisplayController {
    CGDirectDisplayID _builtInID;
    BOOL _isBlackedOut;
    BOOL _applyingChange;
}

- (instancetype)init {
    if (!(self = [super init])) return nil;
    _builtInID = [self discoverBuiltInID];
    _autoBlackoutOnExternalConnect = YES;
    CGDisplayRegisterReconfigurationCallback(displayReconfigCallback,
                                             (__bridge void *)self);
    return self;
}

- (void)dealloc {
    CGDisplayRemoveReconfigurationCallback(displayReconfigCallback,
                                           (__bridge void *)self);
}

- (BOOL)isBlackedOut { return _isBlackedOut; }

// MARK: - Public

- (BOOL)enableBlackout {
    if (_isBlackedOut) return YES;
    if (![self hasActiveExternalDisplay]) {
        NSLog(@"blackoutd: refusing blackout — no active external display");
        return NO;
    }
    [self applyEnable:NO];
    return _isBlackedOut;
}

- (BOOL)disableBlackout {
    if (!_isBlackedOut) return YES;
    [self applyEnable:YES];
    return !_isBlackedOut;
}

// Returns YES only for physically connected external displays.
// Relies on IOKit service presence to exclude virtual/placeholder displays
// inserted by macOS during display transitions.
- (BOOL)hasActiveExternalDisplay {
    CGDirectDisplayID displays[8];
    uint32_t count = 0;
    CGGetActiveDisplayList(8, displays, &count);
    BOOL found = NO;
    for (uint32_t i = 0; i < count; i++) {
        CGDirectDisplayID d = displays[i];
        BOOL builtin    = CGDisplayIsBuiltin(d);
        BOOL hasService = !builtin && displayHasIOKitService(d);
        NSLog(@"blackoutd:   candidate id=%u builtin=%d hasService=%d",
              d, builtin, hasService);
        if (hasService) found = YES;
    }
    return found;
}

- (BOOL)builtInIsOnline {
    CGDirectDisplayID displays[8];
    uint32_t count = 0;
    CGGetOnlineDisplayList(8, displays, &count);
    for (uint32_t i = 0; i < count; i++) {
        if (CGDisplayIsBuiltin(displays[i])) return YES;
    }
    return NO;
}

- (void)adoptBlackedOutState {
    _isBlackedOut = YES;
}

// MARK: - Private

- (void)applyEnable:(BOOL)enable {
    NSLog(@"blackoutd: applyEnable:%d builtInID=%u", enable, _builtInID);

    // Skip the config call if the display is already in the desired state.
    // Another process (e.g. BetterDisplay) may have changed it between the
    // decision to act and this call.
    BOOL currentlyActive = CGDisplayIsActive(_builtInID);
    if (enable == (BOOL)currentlyActive) {
        NSLog(@"blackoutd: applyEnable:%d — already in desired state, syncing", enable);
        _isBlackedOut = !enable;
        [_delegate displayController:self blackoutStateChanged:_isBlackedOut];
        return;
    }

    _applyingChange = YES;
    CGError err = [self setDisplay:_builtInID enabled:enable];
    if (err != kCGErrorSuccess) {
        NSLog(@"blackoutd: %s failed err=%d", enable ? "re-enable" : "disable", err);
        _applyingChange = NO;
        return;
    }
    _isBlackedOut = !enable;
    NSLog(@"blackoutd: applyEnable:%d succeeded — isBlackedOut=%d", enable, _isBlackedOut);
    [_delegate displayController:self blackoutStateChanged:_isBlackedOut];
    dispatch_after(
        dispatch_time(DISPATCH_TIME_NOW, (int64_t)(2.0 * NSEC_PER_SEC)),
        dispatch_get_main_queue(),
        ^{ self->_applyingChange = NO; });
}

- (CGDirectDisplayID)discoverBuiltInID {
    CGDirectDisplayID displays[8];
    uint32_t count = 0;
    CGGetOnlineDisplayList(8, displays, &count);
    for (uint32_t i = 0; i < count; i++) {
        if (CGDisplayIsBuiltin(displays[i])) return displays[i];
    }
    return 1;
}

- (CGError)setDisplay:(CGDirectDisplayID)display enabled:(BOOL)enabled {
    CGDisplayConfigRef config;
    CGError err = CGBeginDisplayConfiguration(&config);
    if (err != kCGErrorSuccess) return err;
    err = CGSConfigureDisplayEnabled(config, display, enabled);
    if (err != kCGErrorSuccess) {
        CGCancelDisplayConfiguration(config);
        return err;
    }
    return CGCompleteDisplayConfiguration(config, kCGConfigurePermanently);
}

- (void)handleReconfiguration:(CGDirectDisplayID)displayID
                         flags:(CGDisplayChangeSummaryFlags)flags {
    if (flags & kCGDisplayBeginConfigurationFlag) return;

    NSLog(@"blackoutd: reconfig displayID=%u flags=0x%x isBlackedOut=%d applyingChange=%d",
          displayID, flags, _isBlackedOut, _applyingChange);

    const CGDisplayChangeSummaryFlags topology =
        kCGDisplayAddFlag | kCGDisplayRemoveFlag |
        kCGDisplayEnabledFlag | kCGDisplayDisabledFlag;
    if (!(flags & topology)) {
        NSLog(@"blackoutd: reconfig — no topology change, skipping");
        return;
    }

    if (_applyingChange) {
        NSLog(@"blackoutd: reconfig suppressed — applyingChange");
        return;
    }

    BOOL hasExternal = [self hasActiveExternalDisplay];
    NSLog(@"blackoutd: hasExternal=%d", hasExternal);

    // Safety invariant: restore built-in whenever no real external is present.
    if (!hasExternal && _isBlackedOut) {
        NSLog(@"blackoutd: no external display — restoring built-in");
        [self applyEnable:YES];
    } else if (hasExternal && _autoBlackoutOnExternalConnect && !_isBlackedOut) {
        NSLog(@"blackoutd: external connected — blacking out built-in");
        [self applyEnable:NO];
    }
}

@end
