BINARY      = blackoutd
INSTALL_BIN = /usr/local/bin/$(BINARY)
AGENT_DIR   = $(HOME)/Library/LaunchAgents
AGENT_PLIST = local.blackoutd.plist
AGENT_DST   = $(AGENT_DIR)/$(AGENT_PLIST)

SRCS   = main.m AppDelegate.m DisplayController.m
CC     = clang
CFLAGS = \
    -fobjc-arc \
    -Wall \
    -Wextra \
    -framework Cocoa \
    -framework CoreGraphics

.PHONY: all clean install-bin install-agent install uninstall load unload reinstall

all: $(BINARY)

$(BINARY): $(SRCS) AppDelegate.h DisplayController.h
	$(CC) $(CFLAGS) -o $@ $(SRCS)

clean:
	rm -f $(BINARY)

# Binary install requires sudo; LaunchAgent plist does not.
install-bin: $(BINARY)
	sudo install -d /usr/local/bin
	sudo install -m 755 $(BINARY) $(INSTALL_BIN)

install-agent:
	install -d $(AGENT_DIR)
	install -m 644 $(AGENT_PLIST) $(AGENT_DST)

install: install-bin install-agent

uninstall: unload
	sudo rm -f $(INSTALL_BIN)
	rm -f $(AGENT_DST)

# launchctl must run as the current user, not root.
load: install
	launchctl bootstrap gui/$$(id -u) $(AGENT_DST)

unload:
	-launchctl bootout gui/$$(id -u)/local.blackoutd 2>/dev/null

reinstall: unload clean all load
