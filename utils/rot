#!/bin/sh
# rot: simple numeric log rotation helper
# Rotates FILE to FILE.N or FILE.N.TAG
# N increments from the highest existing numeric suffix.

usage() {
    printf "usage: rot FILE [TAG]\n" >&2
    exit 1
}

logfile=$1
tag=$2

max_index=-1
max_index_width=0

[ -n "$logfile" ] || usage
[ -e "$logfile" ] || {
    printf "rot: file not found: %s\n" "$logfile" >&2
    exit 1
}

writers=$(lsof -t -- "$logfile" 2>/dev/null)
[ -z "$writers" ] || \
    printf "rot: logfile currently open by PID(s): %s\n" "$writers" >&2

links=$(stat -f %l -- "$logfile") || exit 1
[ "$links" -eq 1 ] || \
    printf "rot: warning: %s has %u hard links\n" "$logfile" "$links" >&2

for candidate in "${logfile}".*; do
    [ -e "$candidate" ] || continue

    suffix=${candidate#"$logfile".}
    index_field=${suffix%%.*}

    case $index_field in
        '' | *[!0-9]*) continue ;;
    esac

    normalized_index=${index_field##0}
    [ -n "$normalized_index" ] || normalized_index=0

    index_width=${#index_field}
    [ "$index_width" -le "$max_index_width" ] || \
        max_index_width=$index_width

    [ "$normalized_index" -le "$max_index" ] || \
        max_index=$normalized_index
done

next_index=$((max_index + 1))

if [ "$max_index_width" -gt 1 ]; then
    formatted_index=$(printf "%0${max_index_width}d" "$next_index")
else
    formatted_index=$next_index
fi

new_name=$logfile.$formatted_index
[ -n "$tag" ] && new_name=$new_name.$tag

mv -- "$logfile" "$new_name"
rotated_file=$new_name

# reopen log file
: > "$logfile" || exit 1

timestamp=$(date +"%Y-%m-%dT%H:%M:%S%z")
host=$(hostname -s)

printf '%s %s rot[%d]: logfile turned over\n' \
    "$timestamp" "$host" "$$" >> "$rotated_file"
